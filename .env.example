# Copy to `.env.local` for Vite dev (or set in Cloudflare Pages → Environment variables).
# Do not put real secrets in the repo. `.env.local` is gitignored.

# Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# After `wrangler deploy` for workers/api-proxy.js (no trailing slash).
# Worker routes: POST /v1/chat, GET /stack-photo, POST /upload-stack-photo,
#   GET /stripe/subscription, POST /stripe/subscription/schedule-downgrade,
#   POST /stripe/create-customer, POST /stripe/create-subscription, POST /stripe/create-portal-session, POST /stripe/webhook
# Wrangler secrets: ANTHROPIC_API_KEY, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
# Stripe (Worker): npx wrangler secret put STRIPE_SECRET_KEY ; npx wrangler secret put STRIPE_WEBHOOK_SECRET
# Optional Worker vars: STRIPE_PRICE_ID_PRO, STRIPE_PRICE_ID_ELITE, STRIPE_PRICE_ID_GOAT (defaults match production price IDs)
# Wrangler vars (production): ENVIRONMENT=production, ALLOWED_ORIGIN=https://your-domain.com
# R2: bind bucket "stack-photos" as STACK_PHOTOS (bucket can stay private; photos are served via GET /stack-photo).
VITE_API_WORKER_URL=

# Cloudflare Turnstile — site key from Cloudflare dashboard (Turnstile → your widget → Site Key).
# Wrangler: npx wrangler secret put TURNSTILE_SECRET_KEY (see wrangler.toml)
VITE_TURNSTILE_SITE_KEY=

# Stripe (browser) — publishable key for embedded Elements (PaymentElement). Never commit secret keys.
# Webhook URL: {VITE_API_WORKER_URL}/stripe/webhook — verify signing secret on the Worker (STRIPE_WEBHOOK_SECRET).
VITE_STRIPE_PUBLISHABLE_KEY=
