# Copy to `.env.local` for Vite dev (or set in Cloudflare Pages → Environment variables).
# Do not put real secrets in the repo. `.env.local` is gitignored.

# Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# After `wrangler deploy` for workers/api-proxy.js (no trailing slash).
# Worker: GET /stripe/subscription, POST /upload-stack-photo (multipart "file"), POST /v1/chat.
# Worker secrets (Wrangler): ANTHROPIC_API_KEY, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, STRIPE_SECRET_KEY (optional).
# Stack photos: bind R2 bucket "stack-photos" as STACK_PHOTOS; set Worker var R2_PUBLIC_BASE_URL (public r2.dev or custom domain, no trailing slash).
VITE_API_WORKER_URL=

# Stripe Payment Links / Checkout URLs (optional — set for production checkout from Upgrade modal)
# VITE_STRIPE_CHECKOUT_PRO=
# VITE_STRIPE_CHECKOUT_ELITE=
# VITE_STRIPE_CHECKOUT_GOAT=
