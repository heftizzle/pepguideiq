# Copy to `.env.local` for Vite dev (or set in Cloudflare Pages → Environment variables).
# Do not put real secrets in the repo. `.env.local` is gitignored.

# Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# After `wrangler deploy` for workers/api-proxy.js (no trailing slash).
# Worker also exposes GET /stripe/subscription (Stripe + profiles.stripe_customer_id); configure Worker secrets in Wrangler, not here.
VITE_API_WORKER_URL=

# Stripe Payment Links / Checkout URLs (optional — set for production checkout from Upgrade modal)
# VITE_STRIPE_CHECKOUT_PRO=
# VITE_STRIPE_CHECKOUT_ELITE=
# VITE_STRIPE_CHECKOUT_GOAT=
