{
  "name": "pepguideiq",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "vite",
    "check:catalog-meta": "node scripts/check-catalog-meta-count.mjs",
    "check:encoding": "node scripts/check-encoding.mjs",
    "build": "pnpm run check:catalog-meta && pnpm run check:encoding && node scripts/generateLabRegistry.js && vite build",
    "preview": "vite preview",
    "lint": "eslint src/ workers/ --ext .js,.jsx",
    "deploy:worker": "wrangler deploy --config wrangler.worker.toml",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@capacitor/cli": "^8",
    "@capacitor/core": "^8",
    "@capacitor/ios": "^8",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^5.10.0",
    "@supabase/supabase-js": "^2.103.3",
    "html2canvas": "^1.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "vite": "^6.0.3",
    "wrangler": "^4.83.0"
  }
}
